# =============================================================================
# JudgeLoom — .gitignore
# =============================================================================

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so

# ─── Virtual Environments ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Django ─────────────────────────────────────────────────────────────────
*.sqlite3
db.sqlite3
/static_collected/
/media/

# ─── Environment & Secrets ─────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── IDE ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Testing & Coverage ───────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Docker ─────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── Celery ─────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Misc ───────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
node_modules/
nul
